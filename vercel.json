{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "functions": {
    "app/**/*.js": {
      "runtime": "nodejs18.x"
    },
    "app/**/*.ts": {
      "runtime": "nodejs18.x"
    },
    "pages/**/*.js": {
      "runtime": "nodejs18.x"
    },
    "pages/**/*.ts": {
      "runtime": "nodejs18.x"
    }
  }
}